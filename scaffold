#!/bin/bash
set -euo pipefail

# scaffold - Initialize AGENTS.md and SKILL.md in a repository
# Usage: scaffold [OPTIONS] [PROJECT_NAME]
#
# Options:
#   -d, --dir DIR      Target directory (default: current directory)
#   -o, --org ORG      GitHub organization (default: auto-detect from git remote)
#   -s, --skill-only   Only create SKILL.md (use existing AGENTS.md)
#   -a, --agents-only  Only create AGENTS.md (skip SKILL.md)
#   -l, --link         Create symlink to global AGENTS.md instead of copying
#   -h, --help         Show this help message

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
AGENTS_TEMPLATE="${SCRIPT_DIR}/AGENTS.md"
SKILL_TEMPLATE="${SCRIPT_DIR}/SKILL.template.md"

usage() {
    sed -n '/^# scaffold/,/^$/p' "$0" | sed 's/^# //'
    exit 0
}

error() {
    echo "error: $1" >&2
    exit 1
}

detect_org() {
    local remote
    remote=$(git remote get-url origin 2>/dev/null || echo "")
    if [[ -n "$remote" ]]; then
        echo "$remote" | sed -E 's|.*[:/]([^/]+)/[^/]+\.git$|\1|' | sed 's/\.git$//'
    else
        echo "ORG"
    fi
}

detect_repo() {
    local remote
    remote=$(git remote get-url origin 2>/dev/null || echo "")
    if [[ -n "$remote" ]]; then
        echo "$remote" | sed -E 's|.*/([^/]+)(\.git)?$|\1|' | sed 's/\.git$//'
    else
        basename "$(pwd)"
    fi
}

to_upper() {
    echo "$1" | tr '[:lower:]-' '[:upper:]_'
}

create_agents() {
    local target_dir="$1"
    local link_mode="$2"
    local agents_file="${target_dir}/AGENTS.md"

    if [[ -f "$agents_file" ]]; then
        echo "AGENTS.md already exists, skipping"
        return 0
    fi

    if [[ "$link_mode" == "true" ]]; then
        ln -sfn "$AGENTS_TEMPLATE" "$agents_file"
        echo "Linked AGENTS.md -> $AGENTS_TEMPLATE"
    else
        cp "$AGENTS_TEMPLATE" "$agents_file"
        echo "Created AGENTS.md"
    fi
}

create_skill() {
    local target_dir="$1"
    local project_name="$2"
    local org="$3"
    local repo="$4"
    local skill_file="${target_dir}/SKILL.md"

    if [[ -f "$skill_file" ]]; then
        echo "SKILL.md already exists, skipping"
        return 0
    fi

    local project_upper
    project_upper=$(to_upper "$project_name")

    sed -e "s/{{PROJECT_NAME}}/${project_name}/g" \
        -e "s/{{PROJECT_NAME_UPPER}}/${project_upper}/g" \
        -e "s/{{GITHUB_ORG}}/${org}/g" \
        -e "s/{{REPO_NAME}}/${repo}/g" \
        -e "s/{{SHORT_DESCRIPTION}}/Architecture, domain rules, and conventions for ${project_name}/g" \
        -e "s/{{LONGER_DESCRIPTION}}/TODO: Add project description/g" \
        -e "s/{{PRODUCTION_URL_OR_DESCRIPTION}}/TODO: Add production URL/g" \
        -e "s/{{SERVICE_NAME}}/core/g" \
        -e "s/{{RESOURCE}}/items/g" \
        -e "s/{{MAIN_FUNCTION}}/process/g" \
        -e "s/{{MODEL_NAME}}/Item/g" \
        -e "s/{{DOMAIN_AREA_1}}/Core Business Rules/g" \
        -e "s/{{DOMAIN_AREA_2}}/Data Validation/g" \
        -e "s/{{DESCRIBE_BUSINESS_RULES}}/TODO: Document business rules/g" \
        -e "s/{{DESCRIBE_MORE_RULES}}/TODO: Document more rules/g" \
        -e "s/{{EXTERNAL_API}}/EXTERNAL/g" \
        -e "s/{{ISSUE_1_TITLE}}/Known Issue 1/g" \
        -e "s/{{ISSUE_2_TITLE}}/Known Issue 2/g" \
        -e "s/{{DESCRIBE_ISSUE_AND_SOLUTION}}/TODO: Document issue/g" \
        -e "s/{{N}}/1/g" \
        -e "s/{{DESCRIPTION}}/TODO/g" \
        "$SKILL_TEMPLATE" > "$skill_file"

    echo "Created SKILL.md (edit to add project-specific details)"
}

link_to_agent_config() {
    local project_name="$1"
    local skill_file="$2"

    local opencode_dir="$HOME/.config/opencode/skills/${project_name}"
    local claude_dir="$HOME/.claude/skills/${project_name}"

    echo ""
    echo "To make this skill available globally, run:"
    echo ""
    echo "  # OpenCode"
    echo "  mkdir -p ${opencode_dir}"
    echo "  ln -sfn ${skill_file} ${opencode_dir}/SKILL.md"
    echo ""
    echo "  # Claude Code"
    echo "  mkdir -p ${claude_dir}"
    echo "  ln -sfn ${skill_file} ${claude_dir}/SKILL.md"
}

main() {
    local target_dir="."
    local org=""
    local project_name=""
    local skill_only=false
    local agents_only=false
    local link_mode=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -d|--dir)
                target_dir="$2"
                shift 2
                ;;
            -o|--org)
                org="$2"
                shift 2
                ;;
            -s|--skill-only)
                skill_only=true
                shift
                ;;
            -a|--agents-only)
                agents_only=true
                shift
                ;;
            -l|--link)
                link_mode=true
                shift
                ;;
            -h|--help)
                usage
                ;;
            -*)
                error "Unknown option: $1"
                ;;
            *)
                project_name="$1"
                shift
                ;;
        esac
    done

    cd "$target_dir" || error "Cannot access directory: $target_dir"

    if [[ -z "$project_name" ]]; then
        project_name=$(detect_repo)
    fi

    if [[ -z "$org" ]]; then
        org=$(detect_org)
    fi

    local repo
    repo=$(detect_repo)

    echo "Scaffolding agent docs for: ${org}/${repo} (project: ${project_name})"
    echo ""

    if [[ "$skill_only" == "false" ]]; then
        create_agents "$(pwd)" "$link_mode"
    fi

    if [[ "$agents_only" == "false" ]]; then
        create_skill "$(pwd)" "$project_name" "$org" "$repo"
        link_to_agent_config "$project_name" "$(pwd)/SKILL.md"
    fi

    echo ""
    echo "Done! Edit the files to add project-specific details."
}

main "$@"
